{
  "name": "open-social-dashboard",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source dashboard for tracking daily follower and subscriber counts from public social profiles without OAuth.",
  "keywords": [
    "social-media",
    "dashboard",
    "analytics",
    "followers",
    "subscribers",
    "scraping",
    "playwright",
    "sqlite",
    "react",
    "typescript"
  ],
  "type": "module",
  "scripts": {
    "collect": "tsx collector/run.ts",
    "summary": "tsx collector/summary.ts",
    "dev": "concurrently -k -n API,WEB -c yellow,cyan \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "APP_API_PORT=8790 tsx watch web/server.ts",
    "dev:web": "APP_API_PORT=8790 vite",
    "build:web": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "express": "^4.21.2",
    "playwright": "^1.51.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.0",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.9",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.6",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^5.4.14"
  }
}
